@startuml
' Expedition Resource Consumed module flow (high level)

title Expedition Resource Consumed module - flow overview

start
partition "POST /expedition-resources-consumed" {
  :Validate recordedBy user + role;
  :Validate expedition status IN_PROGRESS/DELAYED;
  :Validate resource + movement (optional);
  :Create record;
  :Notify roles;
  :Return record;
}

partition "GET /expedition-resources-consumed/:id" {
  :Validate id;
  :Return record (non-admin only own);
}

partition "GET /expedition-resources-consumed" {
  :Validate filters + pagination;
  if (System admin?) then (yes)
    :Use filters;
  else (no)
    :Force recordedBy = current user;
  endif
  :Return list + pagination;
}

partition "PUT /expedition-resources-consumed/:id" {
  :Validate id + ownership;
  :Validate expedition status;
  :Update record;
  :Notify roles;
  :Return record;
}

partition "DELETE /expedition-resources-consumed/:id" {
  :Blocked by policy;
  :Return 403 (audit reasons);
}

end
@enduml
