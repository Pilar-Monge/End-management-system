@startuml
' Inventory Movement module flow (high level)

title Inventory Movement module - flow overview

start
partition "POST /inventory-movements" {
  :Validate campId + recordedBy;
  :Validate camp/resource/user exist;
  :Validate amount by movement type;
  :Check inventory for consumption;
  :Create movement + update camp inventory;
  :Notify low inventory (if needed);
  :Return movement;
}

partition "GET /inventory-movements/:id" {
  :Validate id + camp access;
  :Return movement;
}

partition "GET /inventory-movements" {
  :Validate filters + pagination;
  if (System admin?) then (yes)
    :Use requested campId;
  else (no)
    :Force campId = current user camp;
  endif
  :Return list + pagination;
}

partition "PUT /inventory-movements/:id" {
  :Validate id + camp access;
  :Validate camp/resource/user (optional);
  :Update movement;
  :Notify roles;
  :Return movement;
}

partition "DELETE /inventory-movements/:id" {
  :Blocked by policy;
  :Return 403 (audit reasons);
}

end
@enduml
