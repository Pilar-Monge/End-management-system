@startuml
' Expedition module flow (high level)

title Expedition module - flow overview

start
partition "POST /expeditions" {
  :Validate camp access;
  :Compute planned dates + status;
  :Create expedition;
  :Notify admins + travel manager;
  if (Starts now?) then (yes)
    :Apply departure provisioning;
  endif
  :Return expedition;
}

partition "GET /expeditions/active" {
  :Validate camp access;
  :List IN_PROGRESS + DELAYED expeditions;
  :Return list;
}

partition "GET /expeditions/:id" {
  :Validate id + camp access;
  :Return expedition;
}

partition "GET /expeditions" {
  :Validate filters + pagination;
  if (System admin?) then (yes)
    :Use requested campId;
  else (no)
    :Force campId = current user camp;
  endif
  :Return list + pagination;
}

partition "PUT /expeditions/:id" {
  :Validate id + camp access;
  :Normalize dates/extra days;
  :Update expedition;
  if (Status -> IN_PROGRESS?) then (yes)
    :Apply departure provisioning;
  endif
  :Return expedition;
}

partition "POST /expeditions/:id/complete" {
  :Validate id + camp access;
  :Ensure active participant;
  :Complete expedition + loot;
  :Sync participant statuses;
  :Notify roles;
  :Return expedition;
}

partition "POST /expeditions/:id/force-update-state" {
  :Validate id + camp access;
  :Auto-transition state by time;
  :Return expedition;
}

partition "DELETE /expeditions/:id" {
  :Blocked by policy;
  :Return 403 (audit reasons);
}

end
@enduml
