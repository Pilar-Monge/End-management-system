### Login SYSTEM_ADMIN
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "password",
  "campId": 1
}

### Login WORKER
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "worker_user",
  "password": "password",
  "campId": 1
}

### Login RESOURCE_MANAGEMENT
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "resource_user",
  "password": "password",
  "campId": 1
}

### Login TRAVEL_MANAGER
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "travel_user",
  "password": "password",
  "campId": 1
}

### Login VISITOR
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "visitor_test",
  "password": "password",
  "campId": 1
}

### No token 401
GET {{baseUrl}}/api/users

### SYSTEM_ADMIN accesses users
GET {{baseUrl}}/api/users
Authorization: Bearer {{adminToken}}

### VISITOR forbidden 403
GET {{baseUrl}}/api/users
Authorization: Bearer {{visitorToken}}

### WORKER accesses occupations
GET {{baseUrl}}/api/occupations
Authorization: Bearer {{workerToken}}

### WORKER forbidden 403
GET {{baseUrl}}/api/users
Authorization: Bearer {{workerToken}}

### RESOURCE_MANAGEMENT accesses inventory
GET {{baseUrl}}/api/camp-inventory
Authorization: Bearer {{resourceToken}}

### TRAVEL_MANAGER accesses expeditions
GET {{baseUrl}}/api/expeditions
Authorization: Bearer {{travelToken}}

### TRAVEL_MANAGER forbidden 403
GET {{baseUrl}}/api/users
Authorization: Bearer {{travelToken}}

### Logout
POST {{baseUrl}}/api/auth/logout
Authorization: Bearer {{adminToken}}

### Access after logout 401
GET {{baseUrl}}/api/users
Authorization: Bearer {{logoutToken}}

### Token renewal check
GET {{baseUrl}}/api/occupations
Authorization: Bearer {{workerToken}}

### Create WORKER user
POST {{baseUrl}}/api/users
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "username": "worker_user",
  "password": "Password123!",
  "email": "worker@example.com",
  "role": "WORKER",
  "campId": 1,
  "personId": null,
  "requestId": null
}

