@baseUrl = http://localhost:3000
@token = REPLACE_WITH_VALID_TOKEN
@wrongRoleToken = REPLACE_WITH_WRONG_ROLE_TOKEN

### 1. Login admin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "password",
  "campId": 1
}

### 2. Ruta protegida sin token
GET {{baseUrl}}/api/users

### 3. Ruta protegida con token válido
GET {{baseUrl}}/api/users
Authorization: Bearer {{token}}

### 4. Login visitor
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "visitor_test",
  "password": "password",
  "campId": 1
}

### 5. Ruta protegida con rol incorrecto
GET {{baseUrl}}/api/users
Authorization: Bearer {{wrongRoleToken}}

### 6. Logout exitoso
POST {{baseUrl}}/api/auth/logout
Authorization: Bearer {{token}}